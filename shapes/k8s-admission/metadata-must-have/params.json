{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "metadata-must-have parameters",
  "description": "Parameters for generating a Rego policy that requires specific labels or annotations on a resource.",
  "type": "object",
  "required": ["Package", "MetadataType", "RequiredKeys"],
  "properties": {
    "Package": {
      "type": "string",
      "description": "Rego package name",
      "pattern": "^[a-z][a-z0-9_.]*$"
    },
    "MetadataType": {
      "type": "string",
      "enum": ["labels", "annotations"],
      "description": "Whether to check labels or annotations"
    },
    "RequiredKeys": {
      "type": "array",
      "items": { "type": "string" },
      "description": "List of required label/annotation keys"
    },
    "RegexChecks": {
      "type": "array",
      "description": "Optional regex validation for specific keys",
      "items": {
        "type": "object",
        "required": ["Key", "AllowedRegex"],
        "properties": {
          "Key": { "type": "string" },
          "AllowedRegex": { "type": "string" }
        }
      }
    }
  },
  "additionalProperties": false
}
